# Copy to .env and fill in real values. Never commit .env or .env.local.

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL="postgresql://USER:YOUR_PASSWORD@YOUR_HOST:5432/postgres?sslmode=require"
# Prisma migrations (direct connection; often port 5432 with ?pgbouncer=true on pooler URL for app)
DIRECT_URL="postgresql://USER:YOUR_PASSWORD@YOUR_HOST:5432/postgres?sslmode=require"

# --- Auth & sessions ---
AUTH_SECRET="YOUR_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"

# --- Encrypted password vault (AES key, hex or base64 as implemented) ---
CREDENTIALS_ENCRYPTION_KEY="YOUR_32_BYTE_KEY_HEX_OR_AS_PROVIDED"

# --- Cloudflare R2 (S3-compatible storage for document files) ---
R2_ACCOUNT_ID="YOUR_CLOUDFLARE_ACCOUNT_ID"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET="YOUR_BUCKET_NAME"

# --- Google Cloud Vision / OCR ---
# Either JSON key content (single line) or use GOOGLE_APPLICATION_CREDENTIALS path locally
GOOGLE_CREDENTIALS_JSON=""
# Optional: path to service account file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# API key for Vision REST on Vercel (recommended for serverless)
GOOGLE_VISION_API_KEY="YOUR_GOOGLE_CLOUD_VISION_API_KEY"

# GCS URI for async PDF OCR output (e.g. gs://bucket/prefix/)
GOOGLE_VISION_OCR_GCS_OUTPUT_URI="gs://YOUR_BUCKET/YOUR_PREFIX/"

# Optional: max PDF pages for OCR (number)
# GOOGLE_VISION_PDF_MAX_PAGES="5"

# --- Cron jobs (protect /api/cron/* and /api/cron/backup) ---
CRON_SECRET="YOUR_RANDOM_CRON_SECRET"

# --- Twilio (WhatsApp incoming webhook) ---
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="YOUR_TWILIO_AUTH_TOKEN"

# --- Email (password reset) — Resend ---
RESEND_API_KEY="re_YOUR_RESEND_API_KEY"
# RESEND_FROM="Finance OCR <noreply@yourdomain.com>"

# --- Public app URL (for reset-password links in email) ---
# NEXT_PUBLIC_APP_URL="https://your-production-domain.com"

# --- Optional: OCR in browser (dev / feature flag) ---
# NEXT_PUBLIC_OCR_BROWSER_RUNNER="1"

# --- Optional: WebAuthn / Passkeys display name ---
# PASSKEY_RP_NAME="Finance OCR"

# --- Optional: USD→ILS when API unavailable ---
# USD_ILS_FALLBACK_RATE="3.65"

# The following are usually set automatically by Vercel — do not set locally unless needed:
# VERCEL="1"
# VERCEL_URL="..."
# NODE_ENV="development"
